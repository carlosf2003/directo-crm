>"%APPDIR%\crm-marketplaces.b64" (
  echo 
  echo 
  echo 
  echo 
  echo 
  echo 
  echo 
  echo 
  echo 
  echo 
)
powershell -NoProfile -ExecutionPolicy Bypass -Command "$b64 = Get-Content -Raw '%APPDIR%\crm-marketplaces.b64'; [IO.File]::WriteAllBytes('%TARGET%', [Convert]::FromBase64String($b64))"
